# MedPro AI — Environment Variables
# Copy this file to .env and fill in your values

# === REQUIRED ===
GEMINI_API_KEY=your_gemini_api_key_here

# === OPTIONAL: Email Notifications (Gmail SMTP) ===
# Use a Gmail App Password (NOT your normal Gmail password)
# Get one at: https://myaccount.google.com/apppasswords
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# === OPTIONAL: Langfuse LLM Observability ===
# Sign up at https://cloud.langfuse.com to get these keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxx-xxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxx-xxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# === OPTIONAL: Supabase (Future use) ===
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key
